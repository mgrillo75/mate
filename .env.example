# Main MATE (Multi-Agent Tree Engine) Configuration
# Copy to .env and fill in values
AGENTS_LIST=chess_mate_root
# Authentication (Basic Auth fallback — always available)
AUTH_USERNAME=
AUTH_PASSWORD=

# OAuth 2.0 / OIDC Single Sign-On
# Leave blank to disable a provider; Basic Auth remains available regardless.
#
# Google (OIDC) — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://<your-domain>/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CONF_URL=https://accounts.google.com/.well-known/openid-configuration
#
# GitHub (OAuth 2.0) — create at https://github.com/settings/developers
# Authorization callback URL: https://<your-domain>/auth/callback/github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
#
# General OAuth settings
# SECRET_KEY=<random-32-byte-hex>         # Signs the encrypted session cookie; set in production!
# OAUTH_DEFAULT_ROLE=user                 # Role assigned to new SSO users (user | admin)
# SESSION_SECURE_COOKIE=false             # Set to true behind TLS in production

# Server Configuration
ADK_HOST=127.0.0.1
ADK_PORT=8001
DB_TYPE=sqlite  # postgresql, sqlite or mysql

# PostgreSQL/MySQL settings
DB_HOST=localhost
DB_PORT=5432  # or 3306 for MySQL
DB_NAME=mate_agent
DB_USER=
DB_PASSWORD=

# SQLite (optional path)
DB_PATH=my_agent_data.db

GOOGLE_API_KEY=

# LLM Provider API Keys
# Only set keys for providers you actually use.
# Model prefix in agent config determines which provider is used:
#   gemini-*            → Google Gemini (uses GOOGLE_API_KEY)
#   openai/gpt-4o       → OpenAI
#   anthropic/claude-*   → Anthropic
#   deepseek/deepseek-*  → DeepSeek
#   ollama_chat/model    → Local Ollama (set OLLAMA_API_BASE)
#   openrouter/provider/model → OpenRouter (aggregator)
#   mistral/*, groq/*, cohere/*, together_ai/* → respective providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Ollama (local model hosting)
OLLAMA_API_BASE=http://localhost:11434

# Alternative Local API Servers (defaults are used if not set)
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LLAMACPP_BASE_URL=http://localhost:8080/v1
# LOCALAI_BASE_URL=http://localhost:8080/v1
# LLAMAFILE_BASE_URL=http://localhost:8080/v1

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=public-bucket

ARTIFACT_SERVICE=local_folder

# for gdrive mcp
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_INFO=

# AWS (optional, for S3-compatible artifact storage)
# AWS_ENDPOINT_URL=http://localhost:9000
# AWS_BUCKET_NAME=test-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# OpenTelemetry Distributed Tracing (optional)
# OTEL_TRACING_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=mate
# OTEL_TRACES_DB_EXPORT=true

# Context Compaction (requires ADK >= 1.16.0)
CONTEXT_COMPACTION_ENABLED=false
# CONTEXT_COMPACTION_INTERVAL=3
# CONTEXT_COMPACTION_OVERLAP_SIZE=1
# CONTEXT_COMPACTION_SUMMARIZER_MODEL=

DISTRIBUTION_DOMAIN=mate-static.example.com
DISTRIBUTION_S3_BUCKET_NAME=mate-prod-distribution
DISTRIBUTION_S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com

MCP_EXPOSED_AGENTS=chess_mate_root

# Rate Limits & Budgets (optional)
# RATE_LIMIT_ENABLED=false
# REDIS_URL=redis://localhost:6379  # Optional: distributed rate limiting

# Audit log retention (EU AI Act compliance). 0 = keep forever; N = delete entries older than N days
# AUDIT_RETENTION_DAYS=0
